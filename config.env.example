# byte-by-byte configuration
# Copy this to config.env and fill in your values:
#   cp config.env.example config.env

# Path to this repo (no trailing slash)
BBB_REPO_DIR="/path/to/byte-by-byte"

# OpenClaw binary path
OPENCLAW_BIN="/path/to/openclaw"

# Telegram delivery target (your Telegram user ID)
TELEGRAM_TARGET="YOUR_TELEGRAM_ID"

# Email for daily digest
EMAIL_TARGET="your@email.com"

# Schedule (cron expressions, timezone)
CRON_SCHEDULE="0 8 * * *"
QA_SCHEDULE="15 8 * * *"
TIMEZONE="America/Los_Angeles"

# Model for content generation
MODEL="sonnet"
